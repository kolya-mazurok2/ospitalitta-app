# dependencies
node_modules

# Next.js build output
.next
out

# env files — never commit secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Vercel local config
.vercel

# Claude Code local settings
.claude

# macOS
.DS_Store

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# TypeScript incremental build
*.tsbuildinfo

# Scratch notes / drafts. Files already tracked (CLAUDE.md, README.md, STATUS.md,
# ADMIN-DECISIONS.md, docs/, design/) are unaffected — gitignore does not untrack.
*.md
!CLAUDE.md
!README.md
